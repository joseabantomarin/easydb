# Auth.js / Google OAuth
# Genera AUTH_SECRET con: openssl rand -base64 32
AUTH_SECRET=

# Credenciales de Google Cloud Console (APIs y servicios → Credenciales)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Permite que Auth.js confíe en el host (necesario en LAN/dev fuera de localhost).
AUTH_TRUST_HOST=true
